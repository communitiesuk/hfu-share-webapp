DEBUG=1
SECRET_KEY=foo
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 0.0.0.0 [::1]
CSRF_TRUSTED_ORIGINS=http://localhost:8010 http://127.0.0.1:8010
DB_HOST=database
DB_USERNAME=postgres
DB_PASSWORD=postgres
PAGINATION_PAGE_SIZE=30

# Admin user for seeding
ADMIN_EMAIL=dev@example.com
LOCAL_USER_PASSWORD=passpass

ENTRA_ID_ENABLED=False
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=my-secret
ENTRA_AUTHORITY=https://login.microsoftonline.com/organizations
ENTRA_REDIRECT_URI=http://localhost:8000/auth_callback
ENTRA_LOGOUT_REDIRECT=http://localhost:8000/logout
ENTRA_USERNAME_ATTRIBUTE=oid
ENTRA_SCOPE=User.Read
ENTRA_ALLOWED_TENANTS=00000000-0000-0000-0000-000000000000

# session cookie age - two weeks
SESSION_COOKIE_AGE=1209600
SESSION_SAVE_EVERY_REQUEST=False

SENTRY_ENABLED=False
SENTRY_LOGS_ENABLED=False
SENTRY_CSP_REPORT_URI="/csp-report/"
SENTRY_ENVIRONMENT=local
SENTRY_DSN="" # Retrieve the Sentry DSN URL from AWS Secrets Manager

AWS_REGION=eu-west-2
FILE_DOWNLOAD_S3_BUCKET_NAME=hfu-webapp-attachments-local
AWS_ENDPOINT_URL=http://localhost:4566/

LA_HISTORY_TAB_ENABLED=True
FIX_DUPLICATE_RECORDS_ENABLED=True

# Notify
# NOTIFY_API_KEY=test-api-key
